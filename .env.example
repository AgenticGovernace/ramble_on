# Default AI provider for text-generation workflows.
# Supported values: gemini, openai, anthropic
AI_PROVIDER=gemini

# Gemini configuration
GEMINI_API_KEY=
# Legacy fallback still read by the app for Gemini.
API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-pro
GEMINI_TRANSCRIPTION_MODEL=gemini-2.5-pro
GEMINI_VIDEO_MODEL=veo-2.0-generate-001

# OpenAI configuration
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4.1-mini
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

# Anthropic configuration
ANTHROPIC_API_KEY=
ANTHROPIC_TEXT_MODEL=claude-3-5-sonnet-latest

# MCP / Notion integration
NOTION_API_KEY=
RAMBLE_NOTION_ROOT=
RAMBLE_MCP_PORT=3748

# Electron development
VITE_DEV_SERVER_URL=http://127.0.0.1:5173
