{
  "name": "ramble_on",
  "description": "Ramble On – capture and organize your thoughts",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "license": "SEE LICENSE IN LICENSE",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "ci": "npm run typecheck && npm run test && npm run build",
    "preview": "vite preview",
    "desktop:dev": "concurrently -k \"vite\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "desktop:build": "vite build --base=./ && electron-builder",
    "desktop:build:mac": "vite build --base=./ && electron-builder --mac",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@google/genai": "^0.8.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^11.9.1",
    "chokidar": "^3.6.0",
    "marked": "^4.0.0",
     "zod": "^3.25.76"
  
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^39.8.5",
    "electron-builder": "^26.7.0",
    "jsdom": "^26.0.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.0.18",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.rambleon.app",
    "productName": "Ramble On",
    "directories": {
      "buildResources": "build",
      "output": "dist-electron"
    },
    "files": [
      "dist/**",
      "electron/**",
      "kb/**",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": true,
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Ramble On uses the microphone to record your thoughts.",
        "NSCameraUsageDescription": "Ramble On can use the camera when needed."
      }
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "AgenticGovernace",
        "repo": "ramble_on"
      }
    ],
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
  }
}
