{
  "compilerOptions": {
    /* Language & Environment */
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "jsx": "react-jsx",
    /* Modules & Resolution */
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "isolatedModules": true,
    "allowJs": true,
    "allowImportingTsExtensions": true,
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    /* Type Checking */
    "strict": true,
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    /* Emit */
    "noEmit": true
  }
}